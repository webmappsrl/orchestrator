{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "badinansoft/nova-language-switch": "*",
        "barryvdh/laravel-dompdf": "^3.0",
        "ebess/advanced-nova-media-library": "^5.1",
        "eminiarts/nova-tabs": "^1.5",
        "ezyang/htmlpurifier": "^4.19",
        "guzzlehttp/guzzle": "^7.2",
        "interaction-design-foundation/nova-html-card": "^3.4",
        "laravel/ai": "*",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.25",
        "laravel/nova": "^5.3",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.7",
        "league/flysystem-aws-s3-v3": "^3.12",
        "lorisleiva/laravel-actions": "^2.9",
        "maatwebsite/excel": "^3.1.63",
        "marshmallow/nova-tiptap": "^6.0",
        "overtrue/laravel-favorite": "^5.3",
        "pgvector/pgvector": "^0.2.2",
        "predis/predis": "^2.2",
        "rap2hpoutre/laravel-log-viewer": "^2.4",
        "spatie/db-dumper": "^3.3",
        "spatie/laravel-google-calendar": "^3.8",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-translatable": "^6.3",
        "webklex/laravel-imap": "*",
        "wm/wm-internal": "*",
        "wm/wm-package": "*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://nova.laravel.com"
        },
        {
            "type": "path",
            "url": "./wm-internal"
        },
        {
            "type": "path",
            "url": "./wm-package"
        }
    ]
}
